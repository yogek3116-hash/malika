<!DOCTYPE html>
<html>
<head>
<title>Gift For You ❤️</title>
<style>
body{
margin:0;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:#4b002f;
overflow:hidden;
font-family:sans-serif;
}

.gift{
font-size:100px;
cursor:pointer;
animation:updown 1s infinite alternate;
}

@keyframes updown{
from{transform:translateY(0)}
to{transform:translateY(-15px)}
}

#content{
display:none;
text-align:center;
color:white;
}

img{
width:250px;
height:250px;
object-fit:cover;
border-radius:20px;
}
</style>
</head>
<body>

<div class="gift" onclick="openGift()">🎁</div>

<div id="content">
<img src="foto-kamu.jpg">
<h1>Untuk Kamu ❤️</h1>
<p>Pesan bisa diganti sesuka hati</p>
</div>

<script>
function openGift(){
document.querySelector('.gift').style.display='none';
document.getElementById('content').style.display='block';
}
</script>

</body>
</html>